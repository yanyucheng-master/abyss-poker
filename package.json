    "simulate:skills": "node scripts/simulate-skills.js 1000"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "jest": "^30.1.3",
    "socket.io-client": "^4.8.1"
  }
}
