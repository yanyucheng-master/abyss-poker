{
  "name": "abyss-poker",
  "version": "1.0.0",
  "description": "Realtime heads-up Texas Hold'em web game",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
